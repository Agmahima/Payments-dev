{
   "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": false,
    "noImplicitAny": false
  },
  "include": [
    "./*.ts",
    "./controllers/*.ts",
    "./routes/*.ts",
    "./middleware/*.ts",
    "./utils/*.ts",
    "./types/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}